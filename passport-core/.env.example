PASSPORT_VALIDATOR_RANSAC_THRESHOLD=5.0
PASSPORT_VALIDATOR_MIN_QUAD_AREA_RATIO=0.01
PASSPORT_VALIDATOR_MAX_QUAD_AREA_RATIO=4.0

PASSPORT_FACE_SCORE_THRESHOLD=0.60
PASSPORT_FACE_NMS_THRESHOLD=0.40
PASSPORT_FACE_INPUT_WIDTH=640
PASSPORT_FACE_INPUT_HEIGHT=640
PASSPORT_CANDIDATE_EARLY_STOP_VALIDATION_SCORE=50.0
PASSPORT_CANDIDATE_EARLY_STOP_FACE_SCORE=0.85
PASSPORT_CANDIDATE_EARLY_STOP_LANDMARK_SCORE=0.75
PASSPORT_CANDIDATE_MAX_EXTRACTION_ATTEMPTS=2

PASSPORT_LLM_MODEL=google/gemini-3.1-flash-lite-preview

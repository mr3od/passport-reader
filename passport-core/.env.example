PASSPORT_ASSETS_DIR=assets
PASSPORT_TEMPLATE_PATH=assets/passport_template_v2.jpg
PASSPORT_FACE_MODEL_PATH=assets/face_detection_yunet_2023mar.onnx

PASSPORT_STORAGE_BACKEND=local
PASSPORT_LOCAL_STORAGE_DIR=data
PASSPORT_S3_BUCKET=
PASSPORT_S3_PREFIX=passport-core

PASSPORT_SQLITE_PATH=data/passport_core.sqlite3

PASSPORT_HTTP_TIMEOUT_SECONDS=30
PASSPORT_MAX_DOWNLOAD_BYTES=15728640

PASSPORT_VALIDATOR_MAX_DIMENSION=1800
PASSPORT_VALIDATOR_MAX_FEATURES=5000
PASSPORT_VALIDATOR_RATIO_TEST=0.75
PASSPORT_VALIDATOR_MIN_GOOD_MATCHES=25
PASSPORT_VALIDATOR_MIN_INLIERS=18
PASSPORT_VALIDATOR_MIN_INLIER_RATIO=0.45

PASSPORT_FACE_SCORE_THRESHOLD=0.60

PASSPORT_LLM_PROVIDER=openai_responses
PASSPORT_LLM_MODEL=openai-responses/gpt-5-mini
PASSPORT_GOOGLE_API_KEY=
PASSPORT_OPENAI_API_KEY=
PASSPORT_REQUESTY_BASE_URL=https://router.requesty.ai/v1

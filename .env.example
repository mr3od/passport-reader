# Root local development env for the passport-reader workspace.
# Copy to .env at the repository root and run services with uv from the root.

# passport-core
PASSPORT_ASSETS_DIR=passport-core/assets
PASSPORT_TEMPLATE_PATH=passport_template_v2.jpg
PASSPORT_FACE_MODEL_PATH=face_detection_retinaface_mobile0.25.onnx
PASSPORT_HTTP_TIMEOUT_SECONDS=30
PASSPORT_MAX_DOWNLOAD_BYTES=15728640
PASSPORT_VALIDATOR_SIFT_FEATURES=0
PASSPORT_VALIDATOR_RATIO_TEST=0.75
PASSPORT_VALIDATOR_FLANN_TREES=5
PASSPORT_VALIDATOR_FLANN_CHECKS=64
PASSPORT_VALIDATOR_MIN_GOOD_MATCHES=100
PASSPORT_VALIDATOR_MIN_INLIERS=80
PASSPORT_VALIDATOR_MIN_INLIER_RATIO=0.22
PASSPORT_VALIDATOR_RANSAC_THRESHOLD=5.0
PASSPORT_VALIDATOR_MIN_QUAD_AREA_RATIO=0.01
PASSPORT_VALIDATOR_MAX_QUAD_AREA_RATIO=4.0
PASSPORT_FACE_SCORE_THRESHOLD=0.60
PASSPORT_FACE_NMS_THRESHOLD=0.40
PASSPORT_FACE_INPUT_WIDTH=640
PASSPORT_FACE_INPUT_HEIGHT=640
PASSPORT_CANDIDATE_EARLY_STOP_VALIDATION_SCORE=50.0
PASSPORT_CANDIDATE_EARLY_STOP_FACE_SCORE=0.85
PASSPORT_CANDIDATE_EARLY_STOP_LANDMARK_SCORE=0.75
PASSPORT_CANDIDATE_MAX_EXTRACTION_ATTEMPTS=2
PASSPORT_LLM_MODEL=google/gemini-3.1-flash-lite-preview
PASSPORT_REQUESTY_API_KEY=
PASSPORT_REQUESTY_BASE_URL=https://router.requesty.ai/v1

# passport-platform
PASSPORT_PLATFORM_DB_PATH=data/platform.sqlite3
PASSPORT_PLATFORM_ARTIFACTS_DIR=data/artifacts

# passport-api
PASSPORT_API_HOST=127.0.0.1
PASSPORT_API_PORT=8000
PASSPORT_API_LOG_LEVEL=INFO
PASSPORT_API_DEV_TOKEN_SECRET=

# passport-telegram
PASSPORT_TELEGRAM_BOT_TOKEN=
PASSPORT_TELEGRAM_ALBUM_COLLECTION_WINDOW_SECONDS=1.5
PASSPORT_TELEGRAM_MAX_IMAGES_PER_BATCH=10
PASSPORT_TELEGRAM_LOG_LEVEL=INFO

# passport-admin-bot
PASSPORT_ADMIN_BOT_BOT_TOKEN=
PASSPORT_ADMIN_BOT_ADMIN_USER_IDS=552002791,743379791
PASSPORT_ADMIN_BOT_ADMIN_USERNAMES=mr3od,naaokun
PASSPORT_ADMIN_BOT_LOG_LEVEL=INFO
